NODE_ENV=development
API_PORT=4000
WEB_PORT=5173

# Shared Kafka settings
KAFKA_CLIENT_ID=streambridge
KAFKA_CHUNKS_TOPIC=file-transfer-chunks
KAFKA_METADATA_TOPIC=file-transfer-metadata
KAFKA_EVENTS_TOPIC=file-transfer-events
KAFKA_METRICS_TOPIC=file-transfer-metrics
KAFKA_CHUNK_HINTS_TOPIC=file-transfer-chunk-hints
CHUNK_SIZE_BYTES=524288

# ---- Predictor (EWMA chunk-size controller) ----
PREDICTOR_PORT=4200
PREDICTOR_INTERVAL_MS=10000
PREDICTOR_EWMA_ALPHA=0.2
PREDICTOR_LOW_CHUNK=65536
PREDICTOR_MEDIUM_CHUNK=524288
PREDICTOR_HIGH_CHUNK=2097152

DATA_DIR=./apps/api/data
UPLOAD_DIR=./apps/api/uploads
FRONTEND_API_BASE=http://localhost:4000

# ---- Single-machine defaults ----
KAFKA_BROKERS=localhost:19092

# ---- Two-Mac setup ----
# Mac A (Kafka + API + Worker-A + Web):
#   HOST_IP=<Mac A LAN IP, e.g. 192.168.1.20>   (used by docker compose to advertise Kafka)
#   KAFKA_BROKERS=localhost:19092
#   KAFKA_CONSUMER_GROUP=streambridge-reassembler-A   (worker only)
#
# Mac B (Worker-B only):
#   KAFKA_BROKERS=<Mac A LAN IP>:19092
#   KAFKA_CONSUMER_GROUP=streambridge-reassembler-B
